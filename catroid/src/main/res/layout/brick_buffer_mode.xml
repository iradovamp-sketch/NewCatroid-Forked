<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
    <CheckBox android:id="@+id/brick_checkbox" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" />
    <org.catrobat.catroid.ui.BrickLayout android:id="@+id/brick_buffer_mode_layout" style="@style/BrickContainer.Look.Medium">
        <include layout="@layout/icon_brick_category_look" />
        <TextView style="@style/BrickText.SingleLine" android:text="@string/brick_buffer_mode" />
        <TextView style="@style/BrickText.SingleLine" android:text="Buffer" app:layout_newLine="true"/>
        <TextView android:id="@+id/brick_buffer_name" style="@style/BrickEditText" />
        <TextView style="@style/BrickText.SingleLine" android:text="2D (1/0)" app:layout_newLine="true"/>
        <TextView android:id="@+id/brick_buffer_2d" style="@style/BrickEditText" />
        <TextView style="@style/BrickText.SingleLine" android:text="3D (1/0)" app:layout_newLine="true"/>
        <TextView android:id="@+id/brick_buffer_3d" style="@style/BrickEditText" />
    </org.catrobat.catroid.ui.BrickLayout>
</LinearLayout>