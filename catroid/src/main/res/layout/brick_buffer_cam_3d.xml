<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <CheckBox
        android:id="@+id/brick_checkbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:visibility="gone" />

    <org.catrobat.catroid.ui.BrickLayout
        android:id="@+id/brick_buffer_cam_3d_layout"
        style="@style/BrickContainer.Look.Big">

        <include layout="@layout/icon_brick_category_look" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="@string/brick_buffer_cam_3d" />

        <TextView
            android:id="@+id/brick_buffer_cam_3d_name"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="Pos X"
            app:layout_newLine="true" />
        <TextView
            android:id="@+id/brick_buffer_cam_3d_x"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="Y" />
        <TextView
            android:id="@+id/brick_buffer_cam_3d_y"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="Z" />
        <TextView
            android:id="@+id/brick_buffer_cam_3d_z"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="Yaw"
            app:layout_newLine="true" />
        <TextView
            android:id="@+id/brick_buffer_cam_3d_yaw"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="Pitch" />
        <TextView
            android:id="@+id/brick_buffer_cam_3d_pitch"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="Roll" />
        <TextView
            android:id="@+id/brick_buffer_cam_3d_roll"
            style="@style/BrickEditText" />

        <TextView
            style="@style/BrickText.SingleLine"
            android:text="FOV"
            app:layout_newLine="true" />
        <TextView
            android:id="@+id/brick_buffer_cam_3d_fov"
            style="@style/BrickEditText" />

    </org.catrobat.catroid.ui.BrickLayout>
</LinearLayout>